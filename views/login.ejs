<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login - Il Ricettario</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/partials/base_style.css">
    <link rel="stylesheet" href="/css/partials/navbar.css">

    <link rel="stylesheet" href="/css/partials/footer.css">
    <link rel="stylesheet" href="/css/pages/login.css">
</head>

<body class="d-flex flex-column min-vh-100 bg-light login-page-bg">
    <%- include('partials/navbar') %>

        <main id="main-content" class="flex-grow-1 d-flex align-items-center justify-content-center py-5 px-3">
            <!-- Box principale per l'accesso -->
            <div class="card shadow text-bg-light bg-white border-0 rounded-4 w-100 p-4 p-md-5 login-card"
                data-aos="fade-up">
                <div class="text-center mb-4">
                    <h1 class="h3 fw-bold mb-2 text-dark ls-tight">Bentornato!</h1>
                    <p class="text-secondary small mb-0">Inserisci le tue credenziali per accedere a Il Ricettario</p>
                </div>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 text-danger rounded-3 p-3 mb-4 login-alert-text"
                        role="alert">
                        <span class="fw-bold">Errore:</span>
                        <%= error %>
                    </div>
                    <% } %>



                        <!-- Inserimento email e password -->
                        <form action="/login" method="POST" class="d-flex flex-column gap-3">
                            <div class="form-group mb-2">
                                <label class="form-label fw-semibold small text-dark mb-1" for="usernameOrMail">Email o
                                    Username</label>
                                <div class="input-group form-input-wrapper">
                                    <span class="input-group-text bg-light border-end-0 border text-secondary px-3">
                                        <span class="material-symbols-outlined fs-5">alternate_email</span>
                                    </span>
                                    <input name="usernameOrMail" required
                                        class="form-control bg-light border-start-0 border shadow-none"
                                        id="usernameOrMail" placeholder="chef@ilsaggiante.com" type="text" />
                                </div>
                            </div>

                            <div class="form-group mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label class="form-label fw-semibold small text-dark mb-0"
                                        for="password">Password</label>
                                    <a class="text-decoration-none fw-bold small text-primary custom-text-primary auth-link-hover"
                                        href="/contacts">Password dimenticata?</a>
                                </div>
                                <div class="input-group form-input-wrapper">
                                    <span class="input-group-text bg-light border-end-0 border text-secondary px-3">
                                        <span class="material-symbols-outlined fs-5">lock</span>
                                    </span>
                                    <input name="password" required
                                        class="form-control bg-light border-start-0 border shadow-none" id="password"
                                        placeholder="••••••••" type="password" />
                                </div>
                            </div>

                            <button class="btn btn-primary w-100 fw-bold py-2 custom-btn-primary mt-2" type="submit">
                                Accedi
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-3 border-top border-light">
                            <p class="text-secondary small mb-0">
                                Non hai ancora un account?
                                <a class="text-decoration-none fw-bold custom-text-primary ms-1 auth-link-hover"
                                    href="/registrazione">Registrati ora</a>
                            </p>
                        </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/scripts') %>
</body>

</html>