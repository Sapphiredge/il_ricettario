<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Registrati - Il Ricettario</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/partials/base_style.css">
    <link rel="stylesheet" href="/css/partials/navbar.css">

    <link rel="stylesheet" href="/css/partials/footer.css">
    <link rel="stylesheet" href="/css/pages/register.css">
</head>

<body class="d-flex flex-column min-vh-100 bg-light register-page-bg">
    <%- include('partials/navbar') %>

    <main id="main-content" class="flex-grow-1 d-flex align-items-center justify-content-center py-5 px-3">
        <!-- Scheda modulo registrazione -->
        <div class="card shadow bg-white border-0 rounded-4 w-100 p-4 p-md-5 register-card" data-aos="fade-up">
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold mb-2 text-dark ls-tight">Crea un account</h1>
                <p class="text-secondary small mb-0">Unisciti oggi stesso alla community degli chef de Il Ricettario.</p>
            </div>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-danger border-danger border-opacity-25 text-warning rounded-3 p-3 mb-4 register-alert" role="alert">
                    <%= error %>
                </div>
            <% } %>



            <!-- Form campi dati utente -->
            <form action="/registrazione" method="POST" class="d-flex flex-column gap-3">
                <div class="form-group mb-1">
                    <label class="form-label fw-semibold small text-dark mb-1" for="username">Username</label>
                    <div class="input-group form-input-wrapper">
                        <input name="username" required class="form-control bg-light border shadow-none px-3" id="username" placeholder="mrossi99" type="text" />
                    </div>
                </div>

                <div class="form-group mb-1">
                    <label class="form-label fw-semibold small text-dark mb-1" for="full_name">Nome Completo</label>
                    <div class="input-group form-input-wrapper">
                        <input name="full_name" required class="form-control bg-light border shadow-none px-3" id="full_name" placeholder="Mario Rossi" type="text" />
                    </div>
                </div>

                <div class="form-group mb-1">
                    <label class="form-label fw-semibold small text-dark mb-1" for="email">Indirizzo Email</label>
                    <div class="input-group form-input-wrapper">
                        <input name="email" required class="form-control bg-light border shadow-none px-3" id="email" placeholder="nome@esempio.com" type="email" />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label fw-semibold small text-dark mb-1" for="password">Password</label>
                    <div class="input-group form-input-wrapper">
                        <input name="password" required minlength="8" class="form-control bg-light border shadow-none px-3" id="password" placeholder="••••••••" type="password" />
                    </div>
                    <p class="text-secondary mb-0 mt-1 register-hint-text">Deve contenere almeno 8 caratteri.</p>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 custom-btn-primary shadow-btn">
                    Crea Account
                </button>
            </form>

            <!-- Link rapido per chi ha già un account -->
            <div class="text-center mt-4 pt-3 border-top border-light">
                <p class="text-secondary small mb-0">
                    Hai già un account?
                    <a class="text-decoration-none fw-bold custom-text-primary ms-1 auth-link-hover" href="/login">Accedi</a>
                </p>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <%- include('partials/scripts') %>
</body>
</html>