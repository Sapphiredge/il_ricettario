<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Crea Nuova Ricetta - Il Ricettario</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/partials/base_style.css">
    <link rel="stylesheet" href="/css/partials/navbar.css">

    <link rel="stylesheet" href="/css/partials/footer.css">
    <link rel="stylesheet" href="/css/pages/create_recipe.css">
</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include('partials/navbar') %>

        <main id="main-content" class="flex-grow-1 py-4 py-md-5 px-3">

            <div class="container form-container-md">
                <!-- Intestazione della pagina di creazione -->
                <div class="mb-4 pb-3 border-bottom border-light" data-aos="fade-up">
                    <a class="d-inline-flex align-items-center gap-2 text-decoration-none fw-bold mb-3 custom-text-secondary auth-link-hover"
                        href="/chef/dashboard">
                        <span class="material-symbols-outlined fs-5">arrow_back</span>
                        <span>Torna alla Dashboard</span>
                    </a>
                    <h1 class="display-6 fw-bold text-dark mb-2 ls-tight">Crea Nuova Ricetta
                    </h1>
                    <p class="text-secondary fs-5 m-0">Condividi il tuo capolavoro culinario con il mondo.</p>
                </div>

                <form action="/ricette/creaRicetta" method="POST"
                    class="bg-white p-3 p-md-5 rounded-4 shadow-sm border border-light d-flex flex-column gap-4 gap-md-5"
                    data-aos="fade-up">

                    <!-- Parte 1: Informazioni di base (Titolo, Categoria, ecc.) -->
                    <section>
                        <h2 class="h4 fw-bold text-dark border-bottom pb-2 mb-4">1. Informazioni Base</h2>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-secondary text-uppercase ls-wide">Titolo della
                                Ricetta</label>
                            <input name="title" required class="form-control custom-input shadow-none"
                                placeholder="es: Vera Pizza Napoletana" type="text" />
                        </div>

                        <div class="mb-4">
                            <label
                                class="form-label fw-bold small text-secondary text-uppercase ls-wide">Descrizione</label>
                            <textarea name="description" required
                                class="form-control custom-input shadow-none textarea-md resize-v"
                                placeholder="Descrivi brevemente cosa rende speciale questa ricetta..."></textarea>
                        </div>

                        <div class="row g-4">
                            <div class="col-12 col-md-4">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase ls-wide">Categoria</label>
                                <select name="category" required class="form-select custom-input shadow-none">
                                    <option value="">Seleziona...</option>
                                    <option value="Antipasti">Antipasti</option>
                                    <option value="Primi">Primi</option>
                                    <option value="Secondi">Secondi</option>
                                    <option value="Contorni">Contorni</option>
                                    <option value="Dolci">Dolci</option>
                                    <option value="Condimenti">Condimenti</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase ls-wide">Difficoltà</label>
                                <select name="difficulty" class="form-select custom-input shadow-none">
                                    <option value="Facile">Facile</option>
                                    <option value="Media">Media</option>
                                    <option value="Difficile">Difficile</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label fw-bold small text-secondary text-uppercase ls-wide">Tag
                                    (Opzionali)</label>
                                <input class="form-control custom-input shadow-none" id="tags" name="tags"
                                    placeholder="es: Vegetariano, Veloce" type="text" />
                            </div>
                        </div>
                    </section>

                    <!-- Parte 2: Tempi e calorie -->
                    <section>
                        <h2 class="h4 fw-bold text-dark border-bottom pb-2 mb-4">2. Dettagli</h2>

                        <!-- Row 1: Metodo e Tempi -->
                        <div class="row g-4 mb-4">
                            <div class="col-12 col-md-4">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                    <span class="material-symbols-outlined fs-6">schedule</span> Tempo di Preparazione
                                </label>
                                <div class="input-group">
                                    <input name="prep_time"
                                        class="form-control custom-input text-center fw-bold shadow-none border-end-0"
                                        min="0" placeholder="15" type="number" />
                                    <span
                                        class="input-group-text bg-white border-start-0 text-secondary bg-transparent custom-input">min</span>
                                </div>
                            </div>

                            <div class="col-12 col-md-4">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                    <span class="material-symbols-outlined fs-6">outdoor_grill</span> Tipo di Cottura
                                    (Opz.)
                                </label>
                                <select name="cooking_method" class="form-select custom-input shadow-none">
                                    <option value="">Seleziona...</option>
                                    <option value="Forno">Forno</option>
                                    <option value="Padella">Padella</option>
                                    <option value="Pentola">Pentola</option>
                                    <option value="Griglia">Griglia</option>
                                    <option value="Vapore">Vapore</option>
                                    <option value="Friggitrice">Friggitrice</option>
                                    <option value="Microonde">Microonde</option>
                                    <option value="Nessuna cottura">Nessuna cottura</option>
                                </select>
                            </div>

                            <div class="col-12 col-md-4">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                    <span class="material-symbols-outlined fs-6">outdoor_grill</span> Tempo di Cottura
                                </label>
                                <div class="input-group">
                                    <input name="cook_time"
                                        class="form-control custom-input text-center fw-bold shadow-none border-end-0"
                                        min="0" placeholder="30" type="number" />
                                    <span
                                        class="input-group-text bg-white border-start-0 text-secondary bg-transparent custom-input">min</span>
                                </div>
                            </div>
                        </div>

                        <!-- Row 2: Porzioni e Calorie -->
                        <div class="row g-4 mb-4">
                            <div class="col-12 col-md-6">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                    <span class="material-symbols-outlined fs-6">restaurant</span> Porzioni
                                </label>
                                <input name="servings" class="form-control custom-input text-center fw-bold shadow-none"
                                    min="1" placeholder="4" type="number" />
                            </div>

                            <div class="col-12 col-md-6">
                                <label
                                    class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                    <span class="material-symbols-outlined fs-6">local_fire_department</span> Calorie
                                </label>
                                <div class="input-group">
                                    <input name="calories"
                                        class="form-control custom-input text-center fw-bold shadow-none border-end-0"
                                        min="0" placeholder="450" type="number" />
                                    <span
                                        class="input-group-text bg-white border-start-0 text-secondary bg-transparent custom-input">kcal</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Parte 3: Lista degli ingredienti necessari -->
                    <section>
                        <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-4">
                            <h2 class="h4 fw-bold text-dark m-0">3. Ingredienti</h2>
                            <span class="badge bg-light text-secondary border fs-6" id="contatore-ingredienti">1 / 15</span>
                        </div>
                        <div id="ingredients-list" class="d-flex flex-column gap-3 mb-3">
                            <div class="d-flex align-items-center gap-2 ingredient-row">
                                <input name="ingredient_amounts" required maxlength="6"
                                    class="form-control custom-input shadow-none w-25" placeholder="es. 200g"
                                    type="text" />
                                <input name="ingredient_names" required maxlength="30"
                                    class="form-control custom-input shadow-none flex-grow-1"
                                    placeholder="es. Farina 00" type="text" />
                                <button type="button"
                                    class="btn btn-light text-danger border p-2 d-inline-flex align-items-center justify-content-center btn-danger-hover rounded-3"
                                    title="Rimuovi ingrediente">
                                    <span class="material-symbols-outlined fs-5">delete</span>
                                </button>
                            </div>
                        </div>
                        <button type="button" id="aggiungi-ingrediente"
                            class="btn btn-custom-outline fw-bold px-4 py-2 d-inline-flex gap-2 align-items-center rounded-3">
                            <span class="material-symbols-outlined fs-5">add</span> Aggiungi Ingrediente
                        </button>
                    </section>
 
                    <!-- Parte 4: Istruzioni passo dopo passo -->
                    <section>
                        <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-4">
                            <h2 class="h4 fw-bold text-dark m-0">4. Procedimento</h2>
                            <span class="badge bg-light text-secondary border fs-6" id="contatore-passaggi">1 / 10</span>
                        </div>
                        <div id="instructions-list" class="d-flex flex-column gap-3 mb-3">
                            <div class="d-flex gap-3 instruction-row">
                                <div
                                    class="step-counter text-white fw-bold rounded-circle d-flex align-items-center justify-content-center shadow-sm step-counter-circle">
                                    1</div>
                                <div class="d-flex gap-2 flex-grow-1">
                                    <textarea name="instruction_descriptions" required maxlength="500"
                                        class="form-control custom-input shadow-none textarea-sm resize-v"
                                        placeholder="Descrivi questo passaggio nel dettaglio..."></textarea>
                                    <button type="button"
                                        class="btn btn-light text-danger border p-2 d-inline-flex align-items-center justify-content-center btn-danger-hover rounded-3 align-self-start"
                                        title="Rimuovi passaggio">
                                        <span class="material-symbols-outlined fs-5">delete</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <button type="button" id="aggiungi-istruzione"
                            class="btn btn-custom-outline fw-bold px-4 py-2 d-inline-flex gap-2 align-items-center rounded-3">
                            <span class="material-symbols-outlined fs-5">add</span> Aggiungi Passaggio
                        </button>

                    </section>

                    <!-- Parte 5: Cosa bere con questo piatto -->
                    <section>
                        <h2 class="h4 fw-bold text-dark border-bottom pb-2 mb-4">5. Bevanda consigliata (opzionale)</h2>
                        <div class="mb-4">
                            <label
                                class="form-label fw-bold small text-secondary text-uppercase d-flex align-items-center gap-1 ls-wide">
                                <span class="material-symbols-outlined fs-6">wine_bar</span> L'abbinamento perfetto
                            </label>
                            <input name="suggested_drink" class="form-control custom-input shadow-none"
                                placeholder="es. Un buon calice di Chianti o una birra artigianale..." type="text" />
                        </div>
                    </section>

                    <!-- Submit Area -->
                    <div class="d-flex flex-column flex-sm-row justify-content-between gap-3 pt-4 border-top mt-2">
                        <a href="/chef/dashboard"
                            class="btn btn-light border fw-bold px-4 py-2 d-inline-flex gap-2 align-items-center text-secondary rounded-3">
                            <span class="material-symbols-outlined fs-5">cancel</span> Annulla
                        </a>
                        <button type="submit"
                            class="btn btn-primary custom-btn-primary fw-bold px-4 py-2 d-inline-flex gap-2 align-items-center shadow-btn text-white rounded-3">
                            <span class="material-symbols-outlined fs-5">publish</span> Pubblica ricetta
                        </button>
                    </div>
                </form>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/scripts') %>
                <script type="module" src="/js/recipe-form.js"></script>
</body>

</html>