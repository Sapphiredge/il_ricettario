<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Contatti - Il Ricettario</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/partials/base_style.css">
    <link rel="stylesheet" href="/css/partials/navbar.css">

    <link rel="stylesheet" href="/css/partials/footer.css">
    <link rel="stylesheet" href="/css/pages/contacts.css">
</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include('partials/navbar') %>

        <main id="main-content" class="flex-grow-1 py-5 container" data-aos="fade-up">

            <!-- Scheda informativa dei contatti -->
            <div class="bg-white p-5 rounded-4 shadow-sm text-center mx-auto contacts-card-wrapper">
                <h1 class="display-5 fw-bold text-dark mb-4">Contattaci</h1>
                <p class="fs-5 text-secondary mb-5">
                    Hai domande, suggerimenti o vuoi collaborare con noi? Non esitare a scriverci!
                </p>
                <!-- Elenco dei recapiti disponibili -->
                <div class="d-flex flex-column gap-3 text-start">
                    <div class="d-flex align-items-center gap-3 p-3 border rounded-3 bg-light">
                        <span class="material-symbols-outlined fs-3 contacts-icon-primary">mail</span>
                        <div>
                            <h6 class="mb-0 fw-bold">Email</h6>
                            <h5 class="text-decoration-none text-secondary">info@ilricettario.it</h3>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-3 text-start">
                        <div class="d-flex align-items-center gap-3 p-3 border rounded-3 bg-light">
                            <span class="material-symbols-outlined fs-3 contacts-icon-primary">phone</span>
                            <div>
                                <h6 class="mb-0 fw-bold">Telefono</h6>
                                <h5 class="text-decoration-none text-secondary">+39 0123 456789</h3>
                            </div>
                        </div>
                    </div>
                </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>