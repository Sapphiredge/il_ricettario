<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= category ? category.name : 'Categoria' %> - Il Ricettario
    </title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/partials/recipe-card.css">
    <link rel="stylesheet" href="/css/partials/base_style.css">
    <link rel="stylesheet" href="/css/partials/navbar.css">

    <link rel="stylesheet" href="/css/partials/footer.css">
    <link rel="stylesheet" href="/css/pages/category.css">
</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include('partials/navbar') %>

        <main id="main-content" class="flex-grow-1">
            <!-- Banner con l'immagine della categoria -->
            <div class="position-relative d-flex align-items-center justify-content-center text-center category-hero-banner"
                style="background-image: url('<%= category.image_url %>');">
                <div class="position-absolute top-0 start-0 w-100 h-100 category-hero-overlay"></div>

                <div class="position-relative text-white px-4 category-hero-content" data-aos="fade-up">
                    <span class="d-inline-block fw-bold text-uppercase mb-2 ls-wider">
                        Esplora Categoria
                    </span>
                    <h1 class="fw-bold text-white mb-3">
                        <%= category ? category.name : 'Categoria' %>
                    </h1>
                    <p class="fs-5 opacity-75 mb-0 lh-relaxed">
                        <%= category && category.description ? category.description : 'Scopri tutte le nostre ricette!'
                            %>
                    </p>
                </div>
            </div>

            <!-- Ricette appartenenti alla categoria -->
            <div class="container py-4 py-md-5">
                <div class="d-flex align-items-center gap-2 mb-4 pb-2" data-aos="fade-up">
                    <span class="material-symbols-outlined fs-2 category-stat-icon">restaurant_menu</span>
                    <h2 class="h3 fw-bold m-0 text-dark ls-snug">
                        Tutte le ricette (<%= typeof recipes !=='undefined' && recipes ? recipes.length : 0 %>)
                    </h2>
                </div>

                <% if (typeof recipes !=='undefined' && recipes && recipes.length> 0) { %>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 pt-2">
                        <% recipes.forEach(recipe=> { %>
                            <div class="col">
                                <%- include('partials/recipe-card', { recipe }) %>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <!-- Caso in cui non ci siano ricette -->
                        <div class="text-center bg-white border rounded-4 py-5 px-4 mt-4 shadow-sm">
                            <span class="material-symbols-outlined text-secondary mb-3 icon-xl">inventory_2</span>
                            <h2 class="h4 fw-bold text-dark mb-2">Nessuna ricetta in questa categoria</h2>
                            <p class="text-secondary mx-auto mb-4 category-hero-desc">
                                Non abbiamo ancora ricette qui. I nostri Chef ci stanno lavorando!
                            </p>
                            <a href="/" class="btn btn-primary fw-bold custom-btn-primary px-4 py-2">Esplora altre
                                categorie</a>
                        </div>
                        <% } %>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/scripts') %>
</body>

</html>