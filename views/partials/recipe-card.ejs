<% const card=AiutiCard.getDatiCard(recipe, typeof showActions !=='undefined' ? showActions : false); %>
<% const _removeFromCollection = typeof removeFromCollection !== 'undefined' ? removeFromCollection : null; %>

    <!-- Scheda principale della ricetta con effetti hover -->
    <div class="card h-100 shadow-sm border border-light recipe-card-hover text-decoration-none recipe-card-main"
        data-aos="flip-left">
        <div class="position-absolute top-0 end-0 m-2 z-3 d-flex flex-column gap-2 align-items-end pe-none">
            <% if (recipe.average_rating) { %>
                <div
                    class="badge bg-white shadow-sm d-flex align-items-center gap-1 text-warning pe-auto p-2 recipe-card-rating-badge">
                    <span class="material-symbols-outlined recipe-card-icon-star">star</span>
                    <span class="text-dark fw-bold recipe-card-rating-text">
                        <%= Number(recipe.average_rating).toFixed(1) %>
                    </span>
                </div>
                <% } %>
        </div>


        <!-- Immagine e badge tempo sulla card -->
        <div class="position-relative overflow-hidden recipe-card-img-container">
            <a href="/ricette/<%= recipe.id %>" class="d-block h-100 w-100">
                <img src="<%= card.image %>" alt="<%= recipe.title %>" loading="lazy"
                    class="card-img-top w-100 h-100 object-fit-cover recipe-img-zoom">
                <div
                    class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-0 recipe-overlay-hover recipe-card-overlay">
                </div>
            </a>

            <div class="position-absolute bottom-0 start-0 m-2 d-flex gap-2 pe-none z-3">
                <div
                    class="badge bg-dark bg-opacity-75 d-flex align-items-center gap-1 fw-bold p-1 px-2 recipe-card-glass-badge">
                    <span class="material-symbols-outlined recipe-card-icon-small">schedule</span>
                    <%= card.prepTime %>m
                </div>
                <div
                    class="badge bg-dark bg-opacity-75 d-flex align-items-center gap-1 fw-bold p-1 px-2 recipe-card-glass-badge">
                    <span class="material-symbols-outlined recipe-card-icon-small">outdoor_grill</span>
                    <%= card.cookTime %>m
                </div>
            </div>
        </div>

        <!-- Informazioni centrali (Titolo, Difficoltà) e Autore -->
        <div class="card-body d-flex flex-column p-3">

            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                <a href="/ricette/<%= recipe.id %>"
                    class="card-title text-decoration-none text-dark fw-bold mb-0 recipe-title-hover recipe-card-title ls-snug">
                    <%= recipe.title %>
                </a>
                <span class="badge fw-semibold <%= card.diffBadgeClass %> px-2 py-1 recipe-card-badge flex-shrink-0">
                    <%= card.difficultyLabel %>
                </span>
            </div>


            <div class="mt-auto pt-3 border-top mt-3">
                <% if (card.showActions) { %>
                    <div class="d-flex gap-2 w-100">
                        <button type="button"
                            class="btn btn-light border btn-sm d-flex align-items-center justify-content-center flex-grow-1 recipe-btn-icon-hover text-muted edit-recipe-btn"
                            data-id="<%= recipe.id %>"
                            title="Modifica">
                            <span class="material-symbols-outlined fs-6">edit</span>
                        </button>
                        <button type="button"
                            class="btn btn-light border btn-sm d-flex align-items-center justify-content-center flex-grow-1 text-muted recipe-btn-danger-hover delete-recipe-btn"
                            data-id="<%= recipe.id %>" title="Elimina">
                            <span class="material-symbols-outlined fs-6">delete</span>
                        </button>
                    </div>
                <% } else if (_removeFromCollection) { %>
                    <button type="button"
                        class="btn btn-light border btn-sm d-flex align-items-center justify-content-center w-100 text-muted recipe-btn-danger-hover btn-rimuovi-ricetta"
                        data-collection-id="<%= _removeFromCollection.collectionId %>"
                        data-recipe-id="<%= recipe.id %>"
                        title="Rimuovi dalla raccolta">
                        <span class="material-symbols-outlined fs-6">delete</span>
                    </button>
                <% } else { %>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= card.avatar %>" alt="Chef" loading="lazy"
                            class="rounded-circle border recipe-card-author-avatar" width="24" height="24">
                        <span class="text-muted fw-medium recipe-card-badge">
                            <%= recipe.author_name || 'Chef' %>
                        </span>
                    </div>
                <% } %>
            </div>
        </div>
    </div>